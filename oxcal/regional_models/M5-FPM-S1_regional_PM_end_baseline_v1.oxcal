    // ============================================================
    // 2) REGIONAL PM-END DIAGNOSTIC
    // Core question:
    // how can the regional end of the Middle Palaeolithic be better
    // constrained using strong PM-end anchors and immediately
    // posterior / liminal comparators?
    // ============================================================

    Order("M5-FPM-S1 PM-end regional diagnostic")
    {
      Date("=End AR Level B");
      Date("=End ARB Level-I");
      Date("=Transition Teixoneres Unit III/II");

      Date("=Start AR Level A");
      Date("=Start ARB Level-H");
      Date("=Start FO Unit-IV.1-IV");

      Date("=End S1B");
      Date("=Start 497D");
      Date("=Start RC Layer I-Ia");
      Date("=Boundary Layer IV bottom");
      Date("=Boundary Layer XXIV bottom");

      Date("=Start FO Unit-IIIc");
    };

    Difference("d_EndARLevelB_minus_EndARBLevelI",
      "End AR Level B", "End ARB Level-I");
    Difference("d_EndTXPM_minus_EndARLevelB",
      "Transition Teixoneres Unit III/II", "End AR Level B");
    Difference("d_EndTXPM_minus_EndARBLevelI",
      "Transition Teixoneres Unit III/II", "End ARB Level-I");

    Difference("d_StartARProto_minus_EndARLevelB",
      "Start AR Level A", "End AR Level B");
    Difference("d_StartARProto_minus_EndARBLevelI",
      "Start AR Level A", "End ARB Level-I");
    Difference("d_StartARProto_minus_EndTXPM",
      "Start AR Level A", "Transition Teixoneres Unit III/II");

    Difference("d_StartARBProto_minus_EndARLevelB",
      "Start ARB Level-H", "End AR Level B");
    Difference("d_StartARBProto_minus_EndARBLevelI",
      "Start ARB Level-H", "End ARB Level-I");
    Difference("d_StartARBProto_minus_EndTXPM",
