Plot()
{
  Curve("Atmospheric","intcal20.14c");
  Outlier_Model("General",T(5),U(0,4),"t");
  Sequence("Abric Romani — full sequence structural v1.1")
  {
    Boundary("Start AR Carbonate above J");
    Phase("AR Carbonate above J")
    {
      Date("AR U-series 50400±2600", N(calBP(50400), 2600))
      {
        Outlier("General",0.05);
      };
      Date("AR Age Carbonate above J");
    };
    Boundary("End AR Carbonate above J");

    Boundary("Start AR Level J");
    Phase("AR Level J")
    {
      R_Date("NZA-2316", 47100, 2100)
      {
        Outlier("General",0.05);
      };
      Date("AR Age Level J");
    };
    Boundary("End AR Level J");

    Boundary("Start AR Travertine J-I");
    Phase("AR Travertine J-I")
    {
      Date("AR J-I U-series 46500±1500", N(calBP(46500), 1500))
      {
        Outlier("General",0.05);
      };
      Date("AR J-I U-series 48600±2300", N(calBP(48600), 2300))
      {
        Outlier("General",0.05);
      };
      Date("AR J-I U-series 46900±2600", N(calBP(46900), 2600))
      {
        Outlier("General",0.05);
      };
      Date("AR J-I U-series 46300±2400", N(calBP(46300), 2400))
      {
        Outlier("General",0.05);
      };
      Date("AR J-I U-series 48000±1600", N(calBP(48000), 1600))
      {
        Outlier("General",0.05);
      };
      Date("AR J-I U-series 49200±3300", N(calBP(49200), 3300))
      {
        Outlier("General",0.05);
      };
      Date("AR J-I U-series 47400±2500", N(calBP(47400), 2500))
      {
        Outlier("General",0.05);
      };
      Date("AR J-I U-series 49300±2700", N(calBP(49300), 2700))
      {
        Outlier("General",0.05);
      };
      Date("AR J-I U-series 49300±1600", N(calBP(49300), 1600))
      {
        Outlier("General",0.05);
      };
      Date("AR J-I U-series 49200±2900", N(calBP(49200), 2900))
      {
        Outlier("General",0.05);
      };
      Date("AR Age Travertine J-I");
    };
    Boundary("End AR Travertine J-I");

    Boundary("Start AR Travertine H-I");
    Phase("AR Travertine H-I")
    {
      Date("AR U-series 45100±3100", N(calBP(45100), 3100))
      {
        Outlier("General",0.05);
      };
      Date("AR Age Travertine H-I");
    };
    Boundary("End AR Travertine H-I");

    Boundary("Start AR Level H");
    Phase("AR Level H")
    {
      R_Date("NZA-2315", 44500, 1200)
      {
        Outlier("General",0.05);
      };
      R_Date("CAMS_H", 44100, 5900)
      {
        Outlier("General",0.05);
      };
      Date("AR Age Level H");
    };
    Boundary("End AR Level H");

    Boundary("Start AR Level E");
    Phase("AR Level E")
    {
      R_Date("NZA-2314", 43200, 1100)
      {
        Outlier("General",0.05);
      };
      Date("AR Age Level E");
    };
    Boundary("End AR Level E");

    Boundary("Start AR Carbonate below D");
    Phase("AR Carbonate below D")
    {
      Date("AR U-series 44900±2500", N(calBP(44900), 2500))
      {
        Outlier("General",0.05);
      };
      Date("AR Age Carbonate below D");
    };
    Boundary("End AR Carbonate below D");

    Boundary("Start AR Level D");
    Phase("AR Level D")
    {
      R_Date("NZA-2313", 40680, 940)
      {
        Outlier("General",0.05);
      };
      Date("AR Age Level D");
    };
    Boundary("End AR Level D");

    Boundary("Start AR Level B");
    Phase("AR Level B")
    {
      // Sensibilidad shell marine20:
      // OxA-12025 se trata aquí como concha marina de forma exploratoria.
      // Esta decisión sigue la rotulación de Table 4, pero permanece metodológicamente sensible
      // porque Table 1 del mismo paper la describe como charcoal.
      Curve("Marine20 AR shell B","marine20.14c");
      Delta_R("AR shell Delta_R", -42, 30);

      R_Date("OxA-12025", 39060, 350)
      {
        Outlier("General",0.05);
      };

      Date("AR Age Level B");
    };
    Curve("Atmospheric reset after AR shell B","intcal20.14c");
    Boundary("End AR Level B");

    Boundary("Start AR Carbonates below A");
    Phase("AR Carbonates below A")
    {
      Date("AR U-series 42500±200", N(calBP(42500), 200))
      {
        Outlier("General",0.05);
      };
      Date("AR U-series 42700±200", N(calBP(42700), 200))
      {
        Outlier("General",0.05);
      };
      Date("AR Age Carbonates below A");
    };
    Boundary("End AR Carbonates below A");

    Boundary("Start AR Level A");
    Phase("AR Level A")
    {
      R_Date("AA-8037B", 37900, 1000)
      {
        Outlier("General",0.05);
      };
      R_Date("NZA-2311", 36590, 640)
      {
        Outlier("General",0.05);
      };
      R_Date("AA-7395", 37290, 990)
      {
        Outlier("General",0.05);
      };
      R_Date("OxA-11967", 35900, 600)
      {
        Outlier("General",0.05);
      };
      R_Date("AA-6608", 36740, 920)
      {
        Outlier("General",0.05);
      };
      R_Date("UA1", 37200, 900)
      {
        Outlier("General",0.05);
      };
      R_Date("UA3", 37900, 1000)
      {
        Outlier("General",0.05);
      };

      // Sensibilidad shell marine20:
      // Aquí se usa la redatación válida de Table 3 (36,490 ± 230 BP),
      // no la cifra 36,090 ± 230 de Table 4, porque el valor legacy en F14C
      // publicado por Higham 2014 equivale aproximadamente a 36.5 ka BP.
      Curve("Marine20 AR shell A","marine20.14c");
      Delta_R("=AR shell Delta_R");

      R_Date("OxA-X-2095-46", 36490, 230)
      {
        Outlier("General",0.05);
      };

      Date("AR Age Level A");
    };
    Curve("Atmospheric reset after AR shell A","intcal20.14c");
    Boundary("End AR Level A");

    Boundary("Start AR Carbonates above A");
    Phase("AR Carbonates above A")
    {
      R_Date("USGS-2839", 36300, 1300)
      {
        Outlier("General",0.05);
      };
      Date("AR4 average age", N(calBP(42600), 1100))
      {
        Outlier("General",0.05);
      };
      Date("AR Age Carbonates above A");
    };
    Boundary("End AR Carbonates above A");

    Boundary("End AR full sequence");
  };
};
